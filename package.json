{
  "name": "code-garden",
  "version": "0.1.0",
  "private": true,
  "description": "A living garden interface for understanding and tending codebases.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check 'app/**/*.{ts,tsx,css}' 'lib/**/*.{ts,tsx}' 'scripts/**/*.{mjs,ts}' 'tests/**/*.{ts,tsx}' '*.{json,mjs,ts}'",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "analysis:validate": "node scripts/analysis-validate.mjs",
    "analyze:repo": "tsx scripts/analyze-repo.ts"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.5",
    "tsx": "^4.23.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
